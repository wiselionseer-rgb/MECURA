rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "lucasdanieltrader@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    match /settings/exchangeRate {
      allow read: if true;
      allow write: if isAdmin() || true; // Keeping true for now to ensure update works during testing
    }
    
    match /queue/{patientId} {
      allow read, write: if true;
    }
    
    match /active_consultations/{consultationId}/{document=**} {
      allow read, write: if true;
    }
    
    match /notifications/{notificationId} {
      allow read, write: if true;
    }
    
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
